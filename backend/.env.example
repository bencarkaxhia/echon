# Echon Backend Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to git

# ── App ──────────────────────────────────────────────────────────────────────
DEBUG=True

# ── Security ─────────────────────────────────────────────────────────────────
# REQUIRED in production — generate with: openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days

# ── Database ─────────────────────────────────────────────────────────────────
# Local dev (Docker Compose): port 55432 to avoid clashing with system postgres
DATABASE_URL=postgresql://echon:echon_dev_password@localhost:55432/echon_db
# VPS / Railway example:
# DATABASE_URL=postgresql://echon:PASSWORD@HOST:5432/echon_db

# ── Redis ────────────────────────────────────────────────────────────────────
# Local dev (Docker Compose): port 65379 to avoid clashing with system redis
REDIS_URL=redis://localhost:65379/0
# VPS / Railway example:
# REDIS_URL=redis://HOST:6379/0

# ── File Storage (Cloudflare R2) ─────────────────────────────────────────────
# Leave empty to use local /tmp/echon_uploads (fine for dev, not for prod)
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=echon-media
# Public URL for serving uploaded files (R2 public bucket or custom domain)
CLOUDFLARE_R2_PUBLIC_URL=

# ── Email (SendGrid) ─────────────────────────────────────────────────────────
# Leave empty to disable email invitations
SENDGRID_API_KEY=
FROM_EMAIL=noreply@echon.app

# ── SMS (Twilio) ─────────────────────────────────────────────────────────────
# Leave empty to disable SMS invitations
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=